{
  "name": "hue4cpp",
  "version-string": "0.1.0",
  "description": "A modern C++ library for the Philips Hue V2 API",
  "homepage": "https://github.com/herve-er/hue4cpp",
  "license": "MIT",
  "dependencies": [
    "cpr",
    "nlohmann-json",
    "catch2"
  ],
  "overrides": [
    {
      "name": "mdns",
      "version": "1.4.3"
    }
  ],
  "features": {
    "mdns-discovery": {
      "description": "Enable mDNS bridge discovery",
      "dependencies": [
        {
          "name": "mdns",
          "platform": "!windows"
        },
        {
          "name": "mdnsresponder",
          "platform": "windows"
        }
      ]
    }
  },
  "default-features": [
    "mdns-discovery"
  ]
}
